<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.marketcart.app">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MarketCart">

        <!-- Tela de Splash (inicial) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MarketCart.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Tela principal: lista de compras -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <!-- Tela de itens de uma lista -->
        <activity
            android:name=".activities.ItensActivity"
            android:exported="false" />

        <!-- Formulário: nova lista -->
        <activity
            android:name=".activities.NovaListaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Formulário: novo item -->
        <activity
            android:name=".activities.NovoItemActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
